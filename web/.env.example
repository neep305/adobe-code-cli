# Application Settings
APP_NAME=Adobe AEP Web UI
APP_VERSION=0.1.0
DEBUG=true

# Security (IMPORTANT: Change in production! Min 32 characters)
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-long-please

# Database
DATABASE_URL=postgresql+asyncpg://aep_user:aep_password@postgres:5432/aep_web

# Redis
REDIS_URL=redis://redis:6379/0

# CORS Origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Adobe Experience Platform Credentials
AEP_CLIENT_ID=your_client_id_here
AEP_CLIENT_SECRET=your_client_secret_here
AEP_ORG_ID=your_org_id@AdobeOrg
AEP_TECHNICAL_ACCOUNT_ID=your_technical_account_id@techacct.adobe.com
AEP_SANDBOX_NAME=prod
AEP_TENANT_ID=_yourtenant

# AI Provider API Keys (Optional)
ANTHROPIC_API_KEY=sk-ant-api03-xxx
OPENAI_API_KEY=sk-xxx
AI_PROVIDER=anthropic
