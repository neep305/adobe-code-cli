# Application Settings
APP_NAME="Adobe AEP Web UI"
APP_VERSION="0.1.0"
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-min-32-characters-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://aep_user:aep_password@localhost:5432/aep_web

# Redis
REDIS_URL=redis://localhost:6379/0

# Adobe Experience Platform
AEP_CLIENT_ID=your_client_id_here
AEP_CLIENT_SECRET=your_client_secret_here
AEP_ORG_ID=your_org_id@AdobeOrg
AEP_TECHNICAL_ACCOUNT_ID=your_technical_account_id@techacct.adobe.com
AEP_SANDBOX_NAME=prod
AEP_TENANT_ID=_yourtenant

# AI Providers
ANTHROPIC_API_KEY=sk-ant-api03-xxx
OPENAI_API_KEY=sk-xxx
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-20241022

# Cache TTL (seconds)
CACHE_TTL_TOKEN=82800
CACHE_TTL_SCHEMAS=300
CACHE_TTL_DATASETS=300
CACHE_TTL_AI_RESPONSES=604800

# Upload Settings
MAX_UPLOAD_SIZE_MB=500
UPLOAD_CHUNK_SIZE=1048576

# Monitoring
BATCH_POLL_INTERVAL_SECONDS=10
WS_HEARTBEAT_INTERVAL=30
WS_MESSAGE_MAX_SIZE=1048576
