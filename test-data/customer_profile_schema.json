{
  "$id": "https://ns.adobe.com/acme/schemas/customer-profile",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "title": "Customer Profile Schema",
  "description": "XDM schema for customer profile data with preferences and behavior tracking",
  "type": "object",
  "version": "1.0",
  "meta:class": "https://ns.adobe.com/xdm/context/profile",
  "meta:abstract": false,
  "meta:extends": [
    "https://ns.adobe.com/xdm/context/profile"
  ],
  "allOf": [
    {
      "$ref": "https://ns.adobe.com/xdm/context/profile"
    }
  ],
  "properties": {
    "_id": {
      "title": "Identifier",
      "description": "Unique record identifier",
      "type": "string",
      "format": "uri-reference",
      "meta:xdmField": "@id"
    },
    "_acme": {
      "type": "object",
      "properties": {
        "customerId": {
          "title": "Customer ID",
          "description": "Unique customer identifier used as primary identity",
          "type": "string",
          "maxLength": 100,
          "meta:descriptors": [
            {
              "@type": "xdm:descriptorIdentity",
              "xdm:namespace": "CRM_ID",
              "xdm:property": "xdm:id",
              "xdm:isPrimary": true
            }
          ]
        },
        "age": {
          "title": "Age",
          "description": "Customer age in years",
          "type": "integer",
          "minimum": 0,
          "maximum": 150
        },
        "registrationDate": {
          "title": "Registration Date",
          "description": "Date and time when the customer account was created (ISO 8601)",
          "type": "string",
          "format": "date-time"
        },
        "totalPurchases": {
          "title": "Total Purchases",
          "description": "Total number of purchases made by the customer",
          "type": "number",
          "minimum": 0
        },
        "status": {
          "title": "Status",
          "description": "Current status of the customer account",
          "type": "string",
          "enum": ["active", "inactive", "pending", "churned"],
          "maxLength": 50
        },
        "lifetimeValue": {
          "title": "Lifetime Value",
          "description": "Total monetary value generated by the customer (USD)",
          "type": "number",
          "minimum": 0
        },
        "preferences": {
          "title": "Preferences",
          "description": "Customer communication and notification preferences",
          "type": "object",
          "properties": {
            "newsletter": {
              "title": "Newsletter",
              "description": "Whether the customer has opted in to newsletter emails",
              "type": "boolean"
            },
            "notifications": {
              "title": "Notifications",
              "description": "Whether the customer has opted in to push notifications",
              "type": "boolean"
            },
            "language": {
              "title": "Preferred Language",
              "description": "Customer preferred language code (ISO 639-1)",
              "type": "string",
              "enum": ["en", "ko", "ja", "zh", "fr", "de", "es"],
              "maxLength": 10
            }
          }
        },
        "tags": {
          "title": "Tags",
          "description": "Customer classification tags for segmentation",
          "type": "array",
          "items": {
            "title": "Tag",
            "description": "A single classification tag",
            "type": "string",
            "maxLength": 100
          }
        }
      }
    }
  }
}
